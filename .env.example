# Local RAG: Ollama LLM + sentence-transformers embeddings (no cloud API keys).

# Ollama HTTP API (default: local daemon).
OLLAMA_HOST=http://127.0.0.1:11434
# Chat model (must match `ollama list`, e.g. llama3.1:latest). Run: ollama pull llama3.1
OLLAMA_MODEL=llama3.1:latest

# Sentence-transformers model id (first run downloads weights).
ST_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Backend URL for the Vite dev server (browser → FastAPI).
VITE_API_URL="http://127.0.0.1:8000"

# Optional: embedding batch size, query embedding LRU size.
# EMBED_BATCH_SIZE=32
# QUERY_EMBED_CACHE_MAX=256

# Upload analysis: merged context chunks (head + multi-query retrieval). Defaults 16 / 8.
# ANALYSIS_MAX_CHUNKS=16
# ANALYSIS_K_PER_QUERY=8

# Chat: head chunks + retrieval width. Defaults 10 / 3.
# CHAT_TOP_K=10
# CHAT_HEAD_CHUNKS=3

# Ollama generation limits (avoid truncating long JSON / answers).
# OLLAMA_NUM_CTX=16384
# OLLAMA_NUM_PREDICT_JSON=8192
# OLLAMA_NUM_PREDICT_TEXT=4096

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
