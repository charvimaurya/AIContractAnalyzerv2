{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "framework": "fastapi"
    }
  },
  "rewrites": [
    {
      "source": "/((?!_/backend/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
